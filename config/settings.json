{
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(**)",
      "Bash(*)"
    ],
    "additionalDirectories": ["/etc", "/var", "/tmp", "/opt", "/usr"]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/bin/live_log.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  },
  "channelsEnabled": true,
  "enabledPlugins": {
    "telegram@claude-plugins-official": true
  }
}
